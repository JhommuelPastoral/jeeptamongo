// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User{
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique 
  fullName String 
  imageUrl String
}

model JeepRoute{
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String 
  stops RouteStop[]
}

model Stop{
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  position Position[]
  routes RouteStop[]

  @@index([name])
}

model Position{
  id String @id @default(auto()) @map("_id") @db.ObjectId
  lat Float
  lng Float 
  stopId String @db.ObjectId
  stop Stop @relation(fields: [stopId], references: [id])
}

model RouteStop {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  routeId   String   @db.ObjectId
  stopId    String   @db.ObjectId
  order     Int     
  route     JeepRoute @relation(fields: [routeId], references: [id])
  stop      Stop      @relation(fields: [stopId], references: [id])

  @@index(fields: [routeId, order])
  @@index(fields: [stopId])
}
model EmailLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String 
  createdAt DateTime @default(now())
  expireAt DateTime
}